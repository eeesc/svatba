# Copy to .env.local for local `vercel dev`, or set in Vercel project settings.

# Google Drive folder ID (from the folder URL: .../folders/THIS_PART)
GOOGLE_DRIVE_FOLDER_ID=1n7GYR_Vjrfv2T2DYal5X1GUFh5c5uFSb

# Full service account JSON key as a single-line string (NOT the OAuth client secret).
# Create: Google Cloud Console → IAM → Service Accounts → Keys → Add key → JSON
# Then share your Drive folder with the service account email (Editor).
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional: comma-separated allowed origins for CORS (defaults to same-origin only)
# ALLOWED_ORIGINS=https://your-wedding-site.com,https://www.your-wedding-site.com
